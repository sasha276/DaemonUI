<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:testdaemon.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:m="clr-namespace:testdaemon.Models"
        xmlns:services="clr-namespace:testdaemon.Service"
        xmlns:convertors="clr-namespace:testdaemon.Convertors"
        mc:Ignorable="d" d:DesignHeight="700"
        MinWidth="420" Height="720"
        Width="420"
        x:Class="testdaemon.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Icon.ico"
        Title="Casper"
        Background="#1E1E2E">
    
    <ContentControl Content="{Binding Nav.CurrentPage}"/>
  
</Window>
