<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:testdaemon.ViewModels"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="400"
        Width="400" Height="400"
        Background="#1E1E2E"
        x:Class="testdaemon.Views.CanStreamView"
        Title="CanStreamView"
        x:DataType="viewModels:StreamViewModel">
    
    <Window.Styles>

        <Style Selector="Expander">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style Selector="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,5"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#313244"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="#181825"/>
            <Setter Property="BorderBrush" Value="#313244"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#6C7086"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    
        <Style Selector="Expander:down:expanded /template/ Border#ExpanderContent">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Styles>
    
    <StackPanel>
        
        <StackPanel Orientation="Horizontal" Spacing="15">
            <ToggleSwitch IsChecked="{Binding FloatingWindow}"/>
            <Button Content="Start" Background="GreenYellow" Command="{Binding StartReceivingCommand}" IsEnabled="{Binding !IsActive}"/>
            <Button Content="Stop" Background="DarkRed" Command="{Binding StopReceivingCommand}" IsEnabled="{Binding IsActive}"/>
        </StackPanel>
        
        <ListBox ItemsSource="{Binding Frames}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Prefix}"/>
                        <Separator Width="10" Height="0"/>
                        <TextBlock Text="{Binding Display}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </StackPanel>
</Window>
