<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="testdaemon.App"
             xmlns:local="using:testdaemon"
             xmlns:convertors="clr-namespace:testdaemon.Convertors"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>

                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="BgBrush"        Color="#1E1E2E"/>
                    <SolidColorBrush x:Key="SurfaceBrush"   Color="#181825"/>
                    <SolidColorBrush x:Key="BorderBrush2"   Color="#313244"/>
                    <SolidColorBrush x:Key="TextBrush"      Color="#CDD6F4"/>
                    <SolidColorBrush x:Key="MutedTextBrush" Color="#6C7086"/>
                    <SolidColorBrush x:Key="AccentBrush"    Color="#5980A6"/>
                    <SolidColorBrush x:Key="AccentTextBrush" Color="#F2F2F3"/>
                    <SolidColorBrush x:Key="BracketBrush"   Color="#6C7086"/>
                    <SolidColorBrush x:Key="HoverBrush"     Color="#2A2A3D"/>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="BgBrush"        Color="#F2F2F3"/>
                    <SolidColorBrush x:Key="SurfaceBrush"   Color="#E9E9EA"/>
                    <SolidColorBrush x:Key="BorderBrush2"   Color="#291D1F20"/>
                    <SolidColorBrush x:Key="TextBrush"      Color="#1D1F20"/>
                    <SolidColorBrush x:Key="MutedTextBrush" Color="#8C1D1F20"/>
                    <SolidColorBrush x:Key="AccentBrush"    Color="#5980A6"/>
                    <SolidColorBrush x:Key="AccentTextBrush" Color="#F2F2F3"/>
                    <SolidColorBrush x:Key="BracketBrush"   Color="#8C1D1F20"/>
                    <SolidColorBrush x:Key="HoverBrush"     Color="#121D1F20"/>
                </ResourceDictionary>

            </ResourceDictionary.ThemeDictionaries>

            <convertors:LevelBrushConverter  x:Key="LevelBrush"/>
            <convertors:BoolToBrushConverter x:Key="BoolBrush"/>

            <FontFamily x:Key="BodyFont">Barlow,Segoe UI,system-ui,sans-serif</FontFamily>
            <FontFamily x:Key="CondensedFont">Barlow Condensed,Segoe UI Semibold,system-ui,sans-serif</FontFamily>
            
            <ControlTheme x:Key="BracketCard" TargetType="ContentControl">
                <Setter Property="Padding" Value="14"/>
                <Setter Property="Template">
                    <ControlTemplate>
                        <Panel>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush2}"
                                    BorderThickness="1">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                            <Path Data="M0,5 L0,0 5,0" Stroke="{DynamicResource BracketBrush}" StrokeThickness="1"
                                  HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-6,-6,0,0"/>
                            <Path Data="M0,0 L5,0 5,5" Stroke="{DynamicResource BracketBrush}" StrokeThickness="1"
                                  HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0"/>
                            <Path Data="M0,0 L0,5 5,5" Stroke="{DynamicResource BracketBrush}" StrokeThickness="1"
                                  HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-6,0,0,-6"/>
                            <Path Data="M0,5 L5,5 5,0" Stroke="{DynamicResource BracketBrush}" StrokeThickness="1"
                                  HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-6,-6"/>
                        </Panel>
                    </ControlTemplate>
                </Setter>
            </ControlTheme>

        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.TreeDataGrid/Themes/Fluent.axaml"/>

        <Style Selector="Window, UserControl">
            <Setter Property="Background" Value="{DynamicResource BgBrush}"/>
            <Setter Property="FontFamily" Value="{DynamicResource BodyFont}"/>
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.eyebrow">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="LetterSpacing" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>
        <Style Selector="TextBlock.heading">
            <Setter Property="FontFamily" Value="{DynamicResource CondensedFont}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="18"/>
        </Style>

        <Style Selector="TabItem">
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="TabControl">
            <Setter Property="MinHeight" Value="250"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Expander">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Кнопки: острые углы, тонкая рамка, как в макете -->
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{DynamicResource CondensedFont}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
        </Style>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
        </Style>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style Selector="ToggleButton.segment">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style Selector="ToggleButton.segment:checked">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush2}"/>
        </Style>

        <Style Selector="Expander:down:expanded /template/ Border#ExpanderContent">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Application.Styles>
</Application>